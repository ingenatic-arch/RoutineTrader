# RoutineTrader — local .env template
# Copy to .env for local slash-command mode. NEVER commit .env.
# Cloud routines read these directly from the Routine's env config (no file).

# --- eToro Public API ---
# Constant public key (same for everyone, identifies the app).
ETORO_API_KEY=sdgdskldFPLGfjHn1421dgnlxdGTbngdflg6290bRjslfihsjhSDsdgGHH25hjf

# Your agent-portfolio token (shown ONCE when the portfolio was created).
# MUST be the agent-portfolio key, NOT a main-account key.
# Sanity check: `bash scripts/etoro.sh agent-portfolios` must return HTTP 403.
ETORO_USER_KEY=

# Optional API base override (defaults to https://public-api.etoro.com/api/v1).
# ETORO_API_BASE=https://public-api.etoro.com/api/v1

# --- Perplexity (pre-market research) ---
# If unset, scripts/perplexity.sh exits 3 and prompts fall back to native WebSearch.
PERPLEXITY_API_KEY=
PERPLEXITY_MODEL=sonar

# --- ClickUp Chat (daily/weekly notifications) ---
# All three must be set together. If any missing, clickup.sh appends to local
# DAILY-SUMMARY.md (gitignored) and exits 0 — never crashes the agent.
CLICKUP_API_KEY=
CLICKUP_WORKSPACE_ID=
CLICKUP_CHANNEL_ID=
