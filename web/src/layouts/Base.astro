---
import '../styles/global.css';
import LastBuildBadge from '../components/LastBuildBadge';

interface Props {
  title?: string;
  buildTs: string;
}
const { title = 'RoutineTrader — Dashboard', buildTs }: Props = Astro.props;

const nav = [
  { href: '/', label: 'Overview' },
  { href: '/portfolio', label: 'Portfolio' },
  { href: '/research', label: 'Research' },
  { href: '/weekly', label: 'Weekly' },
  { href: '/issues', label: 'Issues' },
];

const path = new URL(Astro.request.url).pathname.replace(/\/$/, '');
const base = (import.meta.env.BASE_URL ?? '/').replace(/\/$/, '');
const isActive = (href: string) => {
  if (href === '/') return path === '' || path === base;
  return path === `${base}${href}` || path === href;
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content="RoutineTrader agent-portfolio dashboard — percentages only, read-only." />
    <title>{title}</title>
    <link rel="icon" href={`${base}/favicon.svg`} type="image/svg+xml" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" />
  </head>
  <body class="min-h-screen">
    <header class="sticky top-0 z-20 border-b border-line bg-bg/85 backdrop-blur">
      <div class="mx-auto flex max-w-7xl items-center justify-between gap-4 px-4 py-3">
        <a href={base || '/'} class="flex items-center gap-2 !text-ink !no-underline">
          <span class="flex h-7 w-7 items-center justify-center rounded-md bg-pos/15 text-pos">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="h-4 w-4">
              <path d="M3 12h4l3-8 4 16 3-8h4" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
          </span>
          <span class="font-semibold">RoutineTrader</span>
          <span class="chip-muted hidden sm:inline-flex">agent-portfolio</span>
        </a>
        <nav class="flex items-center gap-1 overflow-x-auto">
          {nav.map((n) => (
            <a
              href={`${base}${n.href}`}
              class:list={[
                'rounded-md px-3 py-1.5 text-sm font-medium transition-colors !no-underline',
                isActive(n.href)
                  ? 'bg-bg-muted text-ink'
                  : 'text-ink-muted hover:text-ink hover:bg-bg-muted/60',
              ]}
            >
              {n.label}
            </a>
          ))}
        </nav>
        <div class="hidden md:block">
          <LastBuildBadge client:only="react" fallbackTs={buildTs} />
        </div>
      </div>
    </header>

    <main class="mx-auto max-w-7xl px-4 py-6 md:py-10">
      <slot />
    </main>

    <footer class="mx-auto mt-12 max-w-7xl px-4 pb-8 text-xs text-ink-dim">
      <div class="border-t border-line/60 pt-4 flex flex-wrap items-center justify-between gap-2">
        <span>
          Read-only view. Data lives in
          <a href="https://github.com/ingenatic-arch/RoutineTrader/tree/main/memory" class="underline">memory/*.md</a>.
        </span>
        <span>Percentages only · leverage = 1 · longs only</span>
      </div>
    </footer>
  </body>
</html>
